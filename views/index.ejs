<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <% if (locals.user) { %>
        <p>You are loged in</p>
        <a href="/join-the-club">
            <button>Join the Club</button>
        </a>
        <a href="/message/create">
            <button>Create new message</button>
        </a>
        <% if (locals.user && locals.messages) { %>

        <% messages.forEach(m => { %>
            <h2><%= m.title%></h2>
            <p><%=m.message%></p>
            <%if (locals.user.membership_status === 'member' || locals.user.isadmin) { %>
                <p><%=m.datetime%></p>
                <p><%=m.username%></p>
            <%}%>
            <% if (locals.user.isadmin) { %>
                <form method="post" action="/<%= m.id %>/delete">
                    <button type="submit" sytle="background: transparent; border: none; padding: 0; cursor: pointer;">
                        <img src="images/bin.png">
                    </button>
                </form>
            <%}%>
        <%})%>
    <%}%>
    <%} else {%>
        <h1>Members only club</h1>
        <h2>Welcome back!</h2>
        <p>Please enter your details to access your account.</p>
        <a href="/log-in">
            <button>Log in</button>
        </a>
        <h2>Create an Account</h2>
        <p>Join our community and enjoy all the benefits.</p>
        <a href="/sing-up">
            <button>Sing up</button>
        </a>
        <%if (locals.messages) { %>
            <% messages.forEach(m => { %>
                <h2><%= m.title%></h2>
                <p><%=m.message%></p>
                <p><%=m.datetime%></p>
                <p><%=m.username%></p>
            <%})%> 
        <%}%>
    <%}%>
</body>
</html>