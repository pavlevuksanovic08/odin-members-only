<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Members Only Club</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <% if (locals.user) { %>
            <nav style="display: flex; gap: 12px; margin-bottom: 24px;">
                <a href="/join-the-club"><button type="button">Join the Club</button></a>
                <a href="/message/create"><button type="button">Create new message</button></a>
                <form action="/log-out" method="post" style="margin: 0; padding: 0;">
                    <button type="submit">Log Out</button>
                </form>
            </nav>
        <% } else { %>
            <h1>Members only club</h1>
            <h2>Welcome back!</h2>
            <p>Please enter your details to access your account.</p>
            <a href="/log-in"><button>Log in</button></a>
            <h2>Create an Account</h2>
            <p>Join our community and enjoy all the benefits.</p>
            <a href="/sing-up"><button>Sign up</button></a>
        <% } %>

        <% if (locals.messages) { %>
            <div class="message-list">
                <% messages.forEach(m => { %>
                    <div class="message">
                        <h2><%= m.title %></h2>
                        <p><%= m.message %></p>
                        <% if (locals.user) { %>
                            <% if (locals.user.membership_status === 'member' || locals.user.isadmin) { %>
                                <div class="meta"><%= m.datetime %> | <%= m.username %></div>
                            <% } %>
                            <% if (locals.user.isadmin) { %>
                                <form method="post" action="/message/<%= m.id %>/delete">
                                    <button type="submit" class="deleteBtn">
                                        <img src="images/bin.png" alt="Delete" style="width: 24px; height: 24px;">
                                    </button>
                                </form>
                            <% } %>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</body>
</html>
